# ── Geocoding ─────────────────────────────────────────────────────────────────
# Google Maps Geocoding API key.
# If not set, the app falls back to free Nominatim/OSM geocoding (slower, less accurate).
GOOGLE_MAPS_API_KEY=

# ── OSRM (routing matrix) ─────────────────────────────────────────────────────
# Defaults to the public demo server (unreliable, use self-hosted in production).
# To self-host: add osrm service to docker-compose and set:
# OSRM_URL=http://osrm:5000/table/v1/driving
# OSRM_URL=http://router.project-osrm.org/table/v1/driving

# ── Redis ─────────────────────────────────────────────────────────────────────
# Set automatically by docker-compose (redis://redis:6379).
# Override only if you use an external Redis instance.
# REDIS_URL=redis://localhost:6379

# ── GHCR image overrides (optional) ──────────────────────────────────────────
# Used by docker-compose.prod.yml to pin a specific image tag.
# Defaults to :latest when not set.
# BACKEND_IMAGE=ghcr.io/isakawar/flower-route-optimizer-backend:sha-abc1234
# FRONTEND_IMAGE=ghcr.io/isakawar/flower-route-optimizer-frontend:sha-abc1234
