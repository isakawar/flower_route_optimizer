# ── Geocoding ─────────────────────────────────────────────────────────────────
# Google Maps Geocoding API key.
# If not set, the app falls back to free Nominatim/OSM geocoding (slower, less accurate).
GOOGLE_MAPS_API_KEY=

# ── OSRM (routing matrix) ─────────────────────────────────────────────────────
# Self-hosted OSRM is included in docker-compose and set automatically.
# Override only if you run OSRM externally or want the public demo server.
# OSRM_URL=http://osrm:5000/table/v1/driving         ← docker-compose default
# OSRM_URL=http://router.project-osrm.org/table/v1/driving  ← public (slow)

# ── CRM / External API integration ───────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Use "*" to allow all (not recommended in production).
# ALLOWED_ORIGINS=https://mycrm.com,https://app.mycrm.com
ALLOWED_ORIGINS=http://localhost:3000

# Optional API key for POST /api/optimize/json.
# If empty — auth is disabled (open access).
# API_KEY=your-secret-key-here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Set automatically by docker-compose (redis://redis:6379).
# Override only if you use an external Redis instance.
# REDIS_URL=redis://localhost:6379

# ── GHCR image overrides (optional) ──────────────────────────────────────────
# Used by docker-compose.prod.yml to pin a specific image tag.
# Defaults to :latest when not set.
# BACKEND_IMAGE=ghcr.io/isakawar/flower-route-optimizer-backend:sha-abc1234
# FRONTEND_IMAGE=ghcr.io/isakawar/flower-route-optimizer-frontend:sha-abc1234
