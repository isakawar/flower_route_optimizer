# Copy this file to .env and fill in your values
# cp .env.example .env

# Google Maps Geocoding API key
# If not set, the app falls back to free Nominatim/OSM geocoding (slower, less accurate)
GOOGLE_MAPS_API_KEY=

# Redis URL — set automatically by docker-compose.
# Override only if you run your own Redis instance.
# REDIS_URL=redis://localhost:6379
